# Copy to .env and fill in local values. Never commit the real .env (SEC-1).

# Postgres connection string used by the server and node-pg-migrate.
DATABASE_URL=postgres://leastcount:leastcount@localhost:5432/leastcount

# Secret used to sign express-session cookies. Generate a long random value.
SESSION_SECRET=

# argon2 hash of the single admin password (SEC-2). Never store the plaintext.
ADMIN_PASSWORD_HASH=

# Port the Express/Socket.io server listens on.
PORT=3000

# Origin the client is served from, used for CORS and Socket.io allowed origins.
CLIENT_ORIGIN=http://localhost:5173
