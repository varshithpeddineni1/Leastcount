{
  "name": "least-count",
  "private": true,
  "version": "0.1.0",
  "description": "Least Count — online, real-time, 2-8 player hidden-hand card game (account-free v1).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "server",
    "client",
    "shared",
    "e2e"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "migrate": "npm run migrate -w server --",
    "migrate:create": "npm run migrate:create -w server --",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck -w shared && npm run typecheck -w server && npm run typecheck -w client && npm run typecheck -w e2e",
    "test": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "test:e2e": "npm run test:e2e -w e2e",
    "test:e2e:ui": "npm run test:e2e:ui -w e2e",
    "secretlint": "secretlint --secretlintrc .secretlintrc.json \"**/*\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@vitest/coverage-v8": "^3.0.4",
    "concurrently": "^10.0.3",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "secretlint": "^13.0.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.4"
  }
}
